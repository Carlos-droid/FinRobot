# FinRobot — Configuración de LLMs y APIs
# Copiar a .env y rellenar valores reales:
#   cp .env.example .env

# ═══════════════════════════════════════════════
# LLM Local (Ollama)
# ═══════════════════════════════════════════════
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ═══════════════════════════════════════════════
# NVIDIA NIM (fallback para queries complejas)
# Obtener API Key en: https://build.nvidia.com
# ═══════════════════════════════════════════════
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NIM_TEXT_MODEL=meta/llama-3.3-70b-instruct
USE_NIM_FALLBACK=true

# ═══════════════════════════════════════════════
# APIs Financieras
# ═══════════════════════════════════════════════
FMP_API_KEY=
FINNHUB_API_KEY=
SEC_API_KEY=
FRED_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
